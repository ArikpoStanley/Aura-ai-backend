PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

MONGODB_URI=mongodb://127.0.0.1:27017/aura
MONGODB_MAX_POOL_SIZE=30
MONGODB_MIN_POOL_SIZE=5

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

OTP_EXPIRES_MINUTES=10
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120

# Optional — omit both vars to disable Google OAuth route.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
GOOGLE_AUTH_SUCCESS_REDIRECT_URL=http://localhost:5173/auth/google/success

# Default language for prompts, dialogue, and on-screen text (en = English US)
GENERATION_DEFAULT_LANGUAGE=en

# OpenAI (ChatGPT) — prompts, images (GPT Image), video (Sora), and TTS
OPENAI_API_KEY=
# e.g. gpt-4o-mini (cheaper), gpt-4o (higher quality)
OPENAI_MODEL=gpt-4o-mini
OPENAI_VIDEO_MODEL=sora-2
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_VIDEO_POLL_INTERVAL_MS=5000
OPENAI_VIDEO_MAX_WAIT_MS=900000
OPENAI_IMAGE_TIMEOUT_MS=180000
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- OpenAI media pipeline ---
# Redis + worker for durable jobs (npm run start:worker)
# Upstash: use the TCP URL from the dashboard (rediss://...), NOT "redis-cli --tls -u ..."
REDIS_URL=redis://127.0.0.1:6379
VIDEO_PIPELINE_HYBRID=true
VIDEO_REQUIRE_NARRATION=true
FFMPEG_TEMP_DIR=/tmp/auravid-render
VIDEO_MAX_SECONDS=30
VIDEO_SHORT_SECONDS=10
VIDEO_MEDIUM_SECONDS=20
VIDEO_LONG_SECONDS=30
VIDEO_SEGMENT_MAX_SECONDS=12
VIDEO_LONG_MAX_SEGMENTS=3
# Photos+script uses OpenAI image + OpenAI TTS + FFmpeg Ken Burns by default.
VIDEO_PHOTOS_SCRIPT_KEN_BURNS=true
VIDEO_PHOTOS_SCRIPT_ANIMATE_VIDEO=true
