PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

MONGODB_URI=mongodb://127.0.0.1:27017/aura
MONGODB_MAX_POOL_SIZE=30
MONGODB_MIN_POOL_SIZE=5

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

OTP_EXPIRES_MINUTES=10
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120

# Optional — omit both vars to disable Google OAuth route.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
GOOGLE_AUTH_SUCCESS_REDIRECT_URL=http://localhost:5173/auth/google/success

# Default language for prompts, dialogue, and on-screen text (en = English US)
GENERATION_DEFAULT_LANGUAGE=en

# OpenAI (ChatGPT) — prompt engineering for video/image generation
OPENAI_API_KEY=
# e.g. gpt-4o-mini (cheaper), gpt-4o (higher quality)
OPENAI_MODEL=gpt-4o-mini

REPLICATE_API_TOKEN=
# Set true to use *_PREMIUM model env vars (Kling v3, flux-dev, etc.)
REPLICATE_USE_PREMIUM=false
# Wan T2V/I2V has no audio — when true, routes video to Kling with generate_audio
REPLICATE_VIDEO_GENERATE_AUDIO=true
# Long videos: videoLength "long" → N segments × REPLICATE_SEGMENT_MAX_SECONDS (default ~3 min)
REPLICATE_LONG_VIDEO_TARGET_SECONDS=180
REPLICATE_SEGMENT_MAX_SECONDS=15
REPLICATE_LONG_VIDEO_MAX_SEGMENTS=12
# Photos+script: after flux keyframe, animate with I2V model
REPLICATE_PHOTOS_SCRIPT_ANIMATE_VIDEO=true
REPLICATE_PHOTOS_SCRIPT_IMAGE_INPUT=true

# --- Image models ---
# /ai/images, photos keyframe (standard)
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-schnell
REPLICATE_IMAGE_MODEL_PREMIUM=black-forest-labs/flux-dev
# /ai/characters (standard)
REPLICATE_CHARACTER_IMAGE_MODEL=black-forest-labs/flux-schnell
REPLICATE_CHARACTER_IMAGE_MODEL_PREMIUM=black-forest-labs/flux-dev

# --- Text-to-video: text_to_video, faceless (standard) ---
REPLICATE_VIDEO_T2V_MODEL=wavespeedai/wan-2.1-t2v-480p
REPLICATE_VIDEO_T2V_PREMIUM=kwaivgi/kling-v3-video

# --- Image-to-video: youtube repurpose (with photo), photos animate (standard) ---
REPLICATE_VIDEO_I2V_MODEL=wavespeedai/wan-2.1-i2v-480p
REPLICATE_VIDEO_I2V_PREMIUM=kwaivgi/kling-v3-video

# --- Video remix: /ai/videos/remix (standard) ---
REPLICATE_VIDEO_REMIX_MODEL=wavespeedai/wan-2.1-i2v-480p
REPLICATE_VIDEO_REMIX_PREMIUM=kwaivgi/kling-v3-video

# Legacy fallback (optional; router uses the vars above)
REPLICATE_VIDEO_MODEL=wavespeedai/wan-2.1-t2v-480p

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
