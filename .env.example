PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

MONGODB_URI=mongodb://127.0.0.1:27017/aura
MONGODB_MAX_POOL_SIZE=30
MONGODB_MIN_POOL_SIZE=5

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

OTP_EXPIRES_MINUTES=10
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120

# Optional — omit both vars to disable Google OAuth route.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
GOOGLE_AUTH_SUCCESS_REDIRECT_URL=http://localhost:5173/auth/google/success

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-schnell
REPLICATE_VIDEO_MODEL=kwaivgi/kling-v1.6-standard
# For photos+script: pass first photo URL as `image` to the image model (set to false if your model does not support it).
REPLICATE_PHOTOS_SCRIPT_IMAGE_INPUT=true

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
